# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/research_assistant
POSTGRES_DB=research_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://redis:6379/0

# AI APIs
CLAUDE_API_KEY=your-claude-api-key
# Optional; default claude-haiku-4-5 (3.5 Haiku snapshot IDs return 404 on current API)
# CLAUDE_MODEL=claude-haiku-4-5
PINECONE_API_KEY=your-pinecone-api-key

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Notion MCP export ("Save to Notion" button)
# NOTION_MCP_TOKEN authenticates to Notion's hosted MCP server
# (https://mcp.notion.com/mcp) as a bearer token. NOTION_PARENT_PAGE_ID is
# the Notion page every exported page is created under. Verify against
# Notion's MCP server docs whether a static integration token is accepted,
# or whether a one-time OAuth flow is required to obtain this token.
NOTION_MCP_TOKEN=your-notion-mcp-token
NOTION_PARENT_PAGE_ID=your-notion-parent-page-id

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Social Auth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret 